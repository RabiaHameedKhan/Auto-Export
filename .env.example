# PostgreSQL connection (required for inventory, admin login, inquiries)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/autoexport

# NextAuth - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# After PostgreSQL is running: npm run db:push
# Then load dummy inventory: npm run db:seed
